<header class="bg-white/90 dark:bg-stone-950/90 backdrop-blur-md border-b border-orange-50/50 dark:border-stone-800 shadow-[0_4px_20px_-4px_rgba(242,107,29,0.08)] docked full-width top-0 sticky z-50 flex items-center justify-between px-6 h-16 w-full">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-orange-600 dark:text-orange-400" data-icon="restaurant_menu" style="">restaurant_menu</span>
<h1 class="font-headline-lg text-[20px] text-orange-600 dark:text-orange-500 font-black tracking-tight" style="">Mis Platos</h1>
</div>
<div class="flex items-center gap-2">
<button class="p-2 rounded-full hover:bg-orange-50 transition-colors active:scale-95 duration-200" style="">
<span class="material-symbols-outlined text-stone-500" data-icon="search" style="">search</span>
</button>
<button class="p-2 rounded-full hover:bg-orange-50 transition-colors active:scale-95 duration-200" style="">
<span class="material-symbols-outlined text-stone-500" data-icon="shopping_basket" style="">shopping_basket</span>
</button>
</div>
</header>
<main class="max-w-7xl mx-auto px-5 md:px-margin-desktop py-8">
<!-- Hero Selection Intro -->
<section class="mb-10">
<p class="text-on-surface-variant font-body-lg max-w-2xl" style=""><br/></p>
</section>
<!-- Category Chips -->
<div class="flex gap-3 mb-8 overflow-x-auto pb-4 no-scrollbar">
<button class="px-6 py-2 rounded-full bg-primary-container text-white font-label-md transition-transform active:scale-95" style="">Todos</button>
<button class="px-6 py-2 rounded-full bg-secondary-container/10 text-secondary font-label-md hover:bg-secondary-container/20 transition-all" style="">Pasta</button>
<button class="px-6 py-2 rounded-full bg-tertiary-fixed text-on-tertiary-fixed-variant font-label-md hover:bg-tertiary-fixed/80 transition-all" style="">Ensaladas</button>
<button class="px-6 py-2 rounded-full bg-primary-fixed text-on-primary-fixed-variant font-label-md hover:bg-primary-fixed/80 transition-all" style="">Carnes</button>
<button class="px-6 py-2 rounded-full bg-surface-container-high text-on-surface-variant font-label-md hover:bg-surface-variant transition-all" style="">Postres</button>
</div>
<!-- Dishes Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
<!-- Dish Card 1 (Selected State Example) -->
<div class="group relative bg-surface-container-lowest rounded-[24px] sun-shadow border-2 border-primary-container transition-all hover:-translate-y-1 py-8 px-6">
<div class="absolute top-4 right-4 z-10 bg-primary-container text-white p-1 rounded-full shadow-lg">
<span class="material-symbols-outlined text-[20px]" data-icon="check" style='font-variation-settings: "wght" 700;'>check</span>
</div>
<div class="space-y-2">
<div class="flex justify-between items-start">
<h3 class="font-headline-md text-on-surface" style="">Bowl Mediterráneo</h3>
<span class="font-headline-md text-primary" style="">450 kcal</span>
</div>
<p class="text-on-surface-variant font-body-md line-clamp-2" style="">Quinoa orgánica, garbanzos crujientes, aguacate fresco y un toque de tahini cítrico.</p>
<div class="flex gap-2 pt-2">
<span class="px-2 py-1 bg-tertiary-fixed text-on-tertiary-fixed-variant text-[10px] uppercase font-bold rounded-md" style="">Vegano</span>
<span class="px-2 py-1 bg-secondary-container/20 text-on-secondary-fixed-variant text-[10px] uppercase font-bold rounded-md" style="">Nutritivo</span>
</div>
</div>
</div>
<!-- Dish Card 2 -->
<div class="group relative bg-surface-container-lowest rounded-[24px] sun-shadow border-2 border-transparent hover:border-orange-100 transition-all hover:-translate-y-1 py-8 px-6">
<button class="absolute inset-0 z-0 w-full h-full text-left focus:outline-none focus:ring-2 focus:ring-primary-container rounded-[24px]" style=""></button>
<div class="space-y-2 relative z-10 pointer-events-none">
<div class="flex justify-between items-start">
<h3 class="font-headline-md text-on-surface" style="">Pasta de la Huerta</h3>
<span class="font-headline-md text-primary" style="">620 kcal</span>
</div>
<p class="text-on-surface-variant font-body-md line-clamp-2" style="">Pesto artesanal de albahaca fresca, piñones tostados y auténtico Parmigiano Reggiano.</p>
<div class="flex gap-2 pt-2">
<span class="px-2 py-1 bg-surface-variant text-on-surface-variant text-[10px] uppercase font-bold rounded-md" style="">Vegetariano</span>
</div>
</div>
</div>
<!-- Dish Card 3 -->
<div class="group relative bg-surface-container-lowest rounded-[24px] sun-shadow border-2 border-transparent hover:border-orange-100 transition-all hover:-translate-y-1 py-8 px-6">
<button class="absolute inset-0 z-0 w-full h-full text-left focus:outline-none focus:ring-2 focus:ring-primary-container rounded-[24px]" style=""></button>
<div class="space-y-2 relative z-10 pointer-events-none">
<div class="flex justify-between items-start">
<h3 class="font-headline-md text-on-surface" style="">Pizza Margarita</h3>
<span class="font-headline-md text-primary" style="">580 kcal</span>
</div>
<p class="text-on-surface-variant font-body-md line-clamp-2" style="">Masa madre de 48h, tomate San Marzano y mozzarella di bufala fundida.</p>
<div class="flex gap-2 pt-2">
<span class="px-2 py-1 bg-primary-fixed text-on-primary-fixed-variant text-[10px] uppercase font-bold rounded-md" style="">Popular</span>
</div>
</div>
</div>
<!-- Dish Card 4 -->
<div class="group relative bg-surface-container-lowest rounded-[24px] sun-shadow border-2 border-transparent hover:border-orange-100 transition-all hover:-translate-y-1 py-8 px-6">
<button class="absolute inset-0 z-0 w-full h-full text-left focus:outline-none focus:ring-2 focus:ring-primary-container rounded-[24px]" style=""></button>
<div class="space-y-2 relative z-10 pointer-events-none">
<div class="flex justify-between items-start">
<h3 class="font-headline-md text-on-surface" style="">Salmón Silvestre</h3>
<span class="font-headline-md text-primary" style="">710 kcal</span>
</div>
<p class="text-on-surface-variant font-body-md line-clamp-2" style="">Acompañado de espárragos trigueros y una suave emulsión de limón y eneldo.</p>
<div class="flex gap-2 pt-2">
<span class="px-2 py-1 bg-tertiary-fixed text-on-tertiary-fixed-variant text-[10px] uppercase font-bold rounded-md" style="">Proteína</span>
<span class="px-2 py-1 bg-secondary-container/20 text-on-secondary-fixed-variant text-[10px] uppercase font-bold rounded-md" style="">Sin Gluten</span>
</div>
</div>
</div>
<!-- Dish Card 5 -->
<div class="group relative bg-surface-container-lowest rounded-[24px] sun-shadow border-2 border-transparent hover:border-orange-100 transition-all hover:-translate-y-1 py-8 px-6">
<button class="absolute inset-0 z-0 w-full h-full text-left focus:outline-none focus:ring-2 focus:ring-primary-container rounded-[24px]" style=""></button>
<div class="space-y-2 relative z-10 pointer-events-none">
<div class="flex justify-between items-start">
<h3 class="font-headline-md text-on-surface" style="">Caesar de Pollo</h3>
<span class="font-headline-md text-primary" style="">540 kcal</span>
</div>
<p class="text-on-surface-variant font-body-md line-clamp-2" style="">Pollo de corral a la parrilla, picatostes de masa madre y nuestra salsa secreta.</p>
</div>
</div>
<!-- Dish Card 6 -->
<div class="group relative bg-surface-container-lowest rounded-[24px] sun-shadow border-2 border-transparent hover:border-orange-100 transition-all hover:-translate-y-1 py-8 px-6">
<button class="absolute inset-0 z-0 w-full h-full text-left focus:outline-none focus:ring-2 focus:ring-primary-container rounded-[24px]" style=""></button>
<div class="space-y-2 relative z-10 pointer-events-none">
<div class="flex justify-between items-start">
<h3 class="font-headline-md text-on-surface" style="">Solomillo Angus</h3>
<span class="font-headline-md text-primary" style="">680 kcal</span>
</div>
<p class="text-on-surface-variant font-body-md line-clamp-2" style="">Corte premium con reducción de vino tinto y puré de patata trufado.</p>
</div>
</div>
</div>
<!-- Selection Summary Floating Action -->
<div class="mt-16 flex justify-center">
<button class="bg-primary text-white px-12 py-4 rounded-full font-headline-md shadow-xl hover:scale-105 active:scale-95 transition-all flex items-center gap-3" style="">
<span class="" style="">Continuar Pedido</span>
<span class="material-symbols-outlined" data-icon="arrow_forward" style="">arrow_forward</span>
</button>
</div>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 right-0 z-50 flex justify-around items-center h-20 px-8 pb-4 bg-white dark:bg-stone-900 border-t border-stone-100 dark:border-stone-800 shadow-[0_-4px_20px_-4px_rgba(242,107,29,0.05)] rounded-t-2xl">
<button class="flex flex-col items-center justify-center text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-900/20 rounded-xl px-4 py-1 scale-up-on-tap transition-transform duration-300" style="">
<span class="material-symbols-outlined" data-icon="restaurant" style='font-variation-settings: "FILL" 1;'>restaurant</span>
<span class="font-['Plus_Jakarta_Sans'] text-[11px] font-medium" style="">Platos</span>
</button>
<button class="flex flex-col items-center justify-center text-stone-400 dark:text-stone-500 px-4 py-1 hover:text-orange-500 transition-all scale-up-on-tap duration-300" style="">
<span class="material-symbols-outlined" data-icon="settings_heart" style="">settings_heart</span>
<span class="font-['Plus_Jakarta_Sans'] text-[11px] font-medium" style="">Gestión</span>
</button>
</nav>
